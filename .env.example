# ========================================
# VARIABLES D'ENVIRONNEMENT - SITE WEB OSTÉOPATHE
# ========================================
# Copier ce fichier vers .env.local et configurer les valeurs

# ----------------------------------------
# EMAIL
# ----------------------------------------
# API Resend pour l'envoi d'emails
# Créer un compte sur https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Email de réception des messages du formulaire
CONTACT_EMAIL=contact@exemple.com

# ----------------------------------------
# SITE
# ----------------------------------------
# URL complète du site en production
NEXT_PUBLIC_SITE_URL=https://votre-domaine.com

# Numéro WhatsApp (format international sans +)
# Numéro actuel : 351930505939
NEXT_PUBLIC_WHATSAPP_NUMBER=351930505939

# ----------------------------------------
# ANALYTICS (Optionnel)
# ----------------------------------------
# Google Analytics 4 - Measurement ID
# Format : G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ----------------------------------------
# MAPS (Optionnel)
# ----------------------------------------
# Google Maps API Key
# Obtenir sur https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ----------------------------------------
# SYSTÈME DE RÉSERVATION
# ----------------------------------------
# hCaptcha pour la protection anti-spam
# Créer un compte sur https://www.hcaptcha.com
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-site-key-here
HCAPTCHA_SECRET_KEY=your-secret-key-here

# Base de données
# Local: SQLite (pour développement)
# DATABASE_URL="file:./prisma/dev.db"
# Production: PostgreSQL (Vercel Postgres ou autre)
# Vercel définira automatiquement DATABASE_URL via POSTGRES_PRISMA_URL
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# URL de base pour les liens de validation
# Développement: http://localhost:3000
# Production: https://votre-domaine.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
